---
/**
 * Canadian Mortgage Calculator Page
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import MortgageCalculator from '../features/mortgage/components/MortgageCalculator.jsx';

const title = "Canadian Mortgage Calculator | Accelerated Paydown Tool";
const description = "Calculate your Canadian mortgage payments with semi-annual compounding. Explore how lump sum payments and increased monthly contributions can save you thousands in interest and years off your mortgage.";
---

<BaseLayout 
  title={title} 
  description={description}
>
  
  {/* TITLE SECTION */}
  <header class="max-w-6xl mx-auto px-4 pt-8 text-center md:text-left animate-fade-in">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div>
        <h1 class="text-2xl font-black text-slate-900 flex items-center gap-2 justify-center md:justify-start">
          Mortgage Calculator
        </h1>
        <p class="text-slate-500 text-sm font-medium">
          Canadian specific compounding and accelerated paydown options
        </p>
      </div>

      <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-100 border border-slate-200">
        <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></div>
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-500">
          Semi-Annual Compounding (Fixed Rate)
        </span>
      </div>
    </div>
  </header>

  {/* REACT COMPONENT */}
  <main class="flex-grow flex flex-col justify-center w-full animate-fade-in">
    <MortgageCalculator client:load isVisible={true} />
  </main>

  {/* SEO CONTENT SECTION */}
  <section class="max-w-3xl mx-auto px-6 py-12 text-slate-600 leading-relaxed text-sm">
    <h2 class="text-lg font-bold text-slate-900 mb-4">Canadian Mortgage Rules</h2>
    <p class="mb-4">
      In Canada, mortgage interest compounding rules differ between fixed and variable rates. 
      <strong>Fixed-rate mortgages</strong> are legally required to be compounded semi-annually (twice per year), 
      while <strong>variable-rate mortgages</strong> are typically compounded monthly. 
      This calculator handles these differences automatically.
    </p>
    
    <h3 class="text-md font-bold text-slate-900 mt-6 mb-2">Accelerated Payments</h3>
    <p class="mb-4">
      Choosing "Accelerated Bi-Weekly" or "Accelerated Weekly" payments is one of the easiest ways to pay off your mortgage faster. 
      The "Accelerated" version takes your standard monthly payment and divides it by 2 or 4, respectively. 
      Because there are 26 bi-weekly or 52 weekly periods in a year, you effectively make one extra full monthly payment every year toward your principal.
    </p>

    <h3 class="text-md font-bold text-slate-900 mt-6 mb-2">Prepayment Privileges</h3>
    <p class="mb-8">
      Most Canadian mortgage contracts include "prepayment privileges" that allow you to pay a certain percentage 
      (often 15% or 20%) of the original principal or current balance each year without penalty. 
      Even small monthly increases or annual lump sums can drastically reduce the total interest you pay over the life of the loan.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
      <div class="bg-indigo-50 p-6 rounded-2xl border border-indigo-100">
        <h3 class="font-black text-indigo-900 uppercase tracking-tighter text-sm mb-2">Mortgage Resources</h3>
        <ul class="space-y-3">
          <li>
            <a href="/blog/mortgage-prepayment-guide" class="text-indigo-600 hover:text-indigo-800 font-bold text-sm flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>
              How to Shave 5+ Years Off Your Mortgage
            </a>
          </li>
          <li>
            <a href="/blog/understanding-mortgage-carrying-costs" class="text-indigo-600 hover:text-indigo-800 font-bold text-sm flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>
              Understanding PITH & Carrying Costs
            </a>
          </li>
        </ul>
      </div>

      <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200 flex flex-col justify-between">
        <div>
          <h3 class="font-black text-slate-900 uppercase tracking-tighter text-sm mb-2">Regional Scenarios</h3>
          <p class="text-xs text-slate-500 mb-4 font-medium">Browse localized mortgage calculations for Toronto, Vancouver, Calgary, and more.</p>
        </div>
        <a href="/calculator/mortgage/browse" class="inline-flex items-center justify-center px-4 py-2 bg-white border border-slate-200 rounded-xl text-xs font-black text-slate-700 hover:bg-slate-100 transition-colors uppercase tracking-widest">
          Browse All Scenarios
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
