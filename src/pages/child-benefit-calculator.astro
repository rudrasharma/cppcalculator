---
/**
 * Child Benefit Calculator Page
 * Main page for the Canada Child Benefit calculator
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import HouseholdBenefits from '../features/child-benefit/components/HouseholdBenefits.jsx';
import { TAX_YEAR_CONFIG } from '../config/taxYears.js';
const { CURRENT_APP_YEAR, CCB } = TAX_YEAR_CONFIG;

interface Props {}

const title = `Canada Child Benefit (CCB) Calculator [${CURRENT_APP_YEAR}] | LoonieFi`;
const description = `Estimate your exact ${CURRENT_APP_YEAR} Canada Child Benefit payments instantly. Free, fast calculator for Canadian parents to check monthly CCB based on family net income.`;
const canonicalURL = new URL('/child-benefit-calculator', Astro.site || Astro.url.origin);

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": description,
  "url": canonicalURL.toString(),
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "CAD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the maximum CCB amount for ${CURRENT_APP_YEAR}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `For the ${CURRENT_APP_YEAR} benefit year, the maximum Canada Child Benefit is $${CCB.MAX_UNDER_6.toLocaleString()} per year ($${(CCB.MAX_UNDER_6 / 12).toFixed(2)}/mo) for each child under 6, and $${CCB.MAX_6_TO_17.toLocaleString()} per year ($${(CCB.MAX_6_TO_17 / 12).toFixed(2)}/mo) for each child aged 6 to 17.`
      }
    },
    {
      "@type": "Question",
      "name": "What is the CCB income threshold for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The first income threshold for CCB phase-out in 2026 is $${CCB.THRESHOLD_1.toLocaleString()}. Families with an Adjusted Family Net Income (AFNI) below this amount receive the maximum benefit.`
      }
    }
  ]
};
---

<BaseLayout 
  title={title} 
  description={description}
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  
  {/* TITLE SECTION with Trust Badge */}
  <header class="max-w-6xl mx-auto px-4 pt-8 text-center md:text-left animate-fade-in">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div>
        <h1 class="text-2xl font-black text-slate-900 flex items-center gap-2 justify-center md:justify-start">
          Household Benefits Estimator [{CURRENT_APP_YEAR}]
        </h1>
        <p class="text-slate-500 text-sm font-medium">
          CCB, Trillium, Carbon Rebate & GST Credits
        </p>
      </div>

      {/* TRUST BADGE SPECIFIC TO CCB DATA */}
      <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-100 border border-slate-200">
        <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></div>
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-500">
          Data: CRA Indexed Rates (July {CURRENT_APP_YEAR})
        </span>
      </div>
    </div>
  </header>

  {/* REACT COMPONENT */}
  <main class="flex-grow flex flex-col justify-center w-full animate-fade-in">
    <HouseholdBenefits client:only="react" isVisible={true} />
  </main>

  {/* pSEO LINK SECTION */}
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-4 text-center">
    <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6">
      <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-3">Looking for specific family examples?</p>
      <a 
        href="/calculator/child-benefit/browse" 
        class="inline-flex items-center gap-2 text-sm font-bold text-emerald-600 hover:text-emerald-700 transition-colors hover:underline"
        aria-label="Browse child benefit examples by province and family size"
      >
        Browse Benefits by Province & Family Size
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </section>

  {/* SEO CONTENT SECTION */}
  <section class="max-w-3xl mx-auto px-6 py-12 text-slate-600 leading-relaxed text-sm">
    <h2 class="text-lg font-bold text-slate-900 mb-4">When do CCB payments change?</h2>
    <p class="mb-4">
      The Canada Child Benefit (CCB) is recalculated every July based on your "Adjusted Family Net Income" (AFNI) from the previous year's tax return. For example, payments starting in <strong>July {CURRENT_APP_YEAR}</strong> are based on your <strong>{parseInt(CURRENT_APP_YEAR) - 1} Tax Return</strong>.
    </p>
    <p>
      This calculator uses the latest indexation rates (announced late {parseInt(CURRENT_APP_YEAR) - 1}) to forecast exactly how much your family will receive in the upcoming benefit year.
    </p>
  </section>

</BaseLayout>
