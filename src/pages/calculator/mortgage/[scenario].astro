---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MortgageCalculator from '../../../features/mortgage/components/MortgageCalculator.jsx';
import { MORTGAGE_SCENARIOS } from '../../../data/seo-scenarios.js';
import { calculateAmortization } from '../../../features/mortgage/utils/mortgageEngine.js';
import { calculateLTT, PROVINCES } from '../../../features/mortgage/utils/lttEngine.js';

export const prerender = true;

export function getStaticPaths() {
    return MORTGAGE_SCENARIOS.map(s => ({
        params: { scenario: s.slug },
        props: { ...s }
    }));
}

const { label, desc, principal, homePrice, downPayment, rate, amortization, freq, lumpSums, province, isToronto, isFirstTimeBuyer, showStressTest } = Astro.props;

const initialStateOverride = {
    homePrice: homePrice || principal,
    downPayment: downPayment || 0,
    annualRate: rate,
    amortizationYears: amortization,
    paymentFrequency: freq,
    province: province || 'ON',
    isToronto: isToronto || false,
    isFirstTimeBuyer: isFirstTimeBuyer || false,
    showStressTest: showStressTest || false,
    lumpSums: lumpSums ? lumpSums.map((ls, i) => ({
        id: Date.now() + i,
        amount: ls.amount,
        // Calculate date based on offsetYears if provided, otherwise default next year
        date: (() => {
            const d = new Date();
            d.setFullYear(d.getFullYear() + (ls.offsetYears || 1));
            return d.toISOString().split('T')[0];
        })()
    })) : undefined
};

// Remove undefined fields so we don't accidentally overwrite defaults with undefined
Object.keys(initialStateOverride).forEach(key => initialStateOverride[key] === undefined && delete initialStateOverride[key]);

// SERVER SIDE MATH FOR SEO INJECTIONS
const safeHomePrice = homePrice || principal || 500000;
const safeDownPayment = downPayment || 0;
const safeRate = rate || 5.0;
const safeAmortization = amortization || 25;
const safeFreq = freq || 'monthly';
const safeProvince = province || 'ON';

const serverResults = calculateAmortization({
    homePrice: safeHomePrice,
    downPayment: safeDownPayment,
    annualRate: safeRate,
    amortizationYears: safeAmortization,
    paymentFrequency: safeFreq
});

const lttResults = calculateLTT(safeHomePrice, safeProvince, isToronto, isFirstTimeBuyer);

const formatter = new Intl.NumberFormat('en-CA', { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 });
const monthlyPaymentStr = formatter.format(serverResults.monthlyPayment);
const totalInterestStr = formatter.format(serverResults.totalInterest);
const totalCostStr = formatter.format(serverResults.totalCost);
const homePriceStr = formatter.format(safeHomePrice);
const lttStr = formatter.format(lttResults.totalTax);
const provinceName = PROVINCES[safeProvince];

const canonicalURL = new URL(`/calculator/mortgage/${Astro.params.scenario}`, Astro.site || Astro.url.origin);

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": `${label} - LoonieFi`,
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "CAD"
  },
  "description": desc
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the payment on a ${homePriceStr} mortgage at ${safeRate}%?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Assuming a ${safeAmortization}-year amortization and no down payment, the estimated regular payment would be ${monthlyPaymentStr} per ${safeFreq.replace('-', ' ')}.`
      }
    },
    {
      "@type": "Question",
      "name": `How much interest will I pay on a ${homePriceStr} mortgage?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Over the entire ${safeAmortization}-year life of the loan at ${safeRate}%, you would pay approximately ${totalInterestStr} in total interest. This brings the total cost of the mortgage to ${totalCostStr}.`
      }
    },
    {
      "@type": "Question",
      "name": "How is this Canadian mortgage calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In Canada, fixed-rate mortgages are legally required to be compounded semi-annually, not monthly. This calculator uses the exact semi-annual compounding formula to ensure the payment matches what a Canadian bank would quote."
      }
    }
  ]
};
---

<BaseLayout 
  title={`${label} - Free Canadian Calculator`} 
  description={desc}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <header class="max-w-6xl mx-auto px-4 pt-8 pb-4 text-center md:text-left animate-fade-in">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div>
        <h1 class="text-2xl font-black text-slate-900 flex items-center gap-2 justify-center md:justify-start">
          {label}
        </h1>
        <p class="text-slate-500 text-sm font-medium">
          {desc}
        </p>
      </div>

      <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-100 border border-slate-200">
        <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse" aria-hidden="true"></div>
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-500">
          Canadian Compounding Rules
        </span>
      </div>
    </div>
  </header>

  <main class="flex-grow flex flex-col justify-center w-full animate-fade-in relative z-10">
      <MortgageCalculator key={Astro.params.scenario} client:load isVisible={true} initialStateOverride={initialStateOverride} />
  </main>

  {/* SEO CONTENT SECTION */}
  <section class="max-w-3xl mx-auto px-6 py-12 text-slate-600 leading-relaxed text-sm animate-fade-in space-y-8">
    
    <div>
        <h2 class="text-xl font-black text-slate-900 mb-4 tracking-tight">Scenario Breakdown</h2>
        <p class="mb-4">
        Based on the current inputs, if you are purchasing a <strong>{homePriceStr}</strong> home in <strong>{provinceName}{isToronto ? ' (Toronto)' : ''}</strong> with an interest rate of <strong>{safeRate}%</strong>, your estimated base payment will be <strong>{monthlyPaymentStr}</strong> ({safeFreq.replace('-', ' ')}). 
        </p>
        <p class="mb-4">
        Beyond the mortgage payment, your estimated <strong>Land Transfer Tax (LTT)</strong> for this transaction is <strong>{lttStr}</strong>. 
        {isFirstTimeBuyer ? 'This includes first-time home buyer rebates applied at the provincial' + (isToronto ? ' and municipal' : '') + ' level.' : 'If you are a first-time home buyer, you may be eligible for significant rebates on this tax.'}
        </p>
        <p class="mb-4">
        Over the course of your <strong>{safeAmortization}-year</strong> amortization, you can expect to pay a total of <strong>{totalInterestStr}</strong> in interest to the lender, bringing your true total cost of ownership to <strong>{totalCostStr}</strong> (excluding property taxes and maintenance).
        </p>
        <p>
        Use the prepayments tab in the calculator above to see how adding small monthly increases or annual lump-sum payments can drastically cut down this interest and shave years off your mortgage.
        </p>
    </div>

    <div>
        <h2 class="text-xl font-black text-slate-900 mb-4 tracking-tight">Frequently Asked Questions</h2>
        <div class="space-y-4">
            <div class="bg-slate-50 rounded-2xl p-5 border border-slate-100">
                <h3 class="font-bold text-slate-900 mb-2">How much is the land transfer tax in {provinceName}?</h3>
                <p class="text-slate-600 text-sm">For a {homePriceStr} home in {provinceName}, the estimated tax is {lttStr}. This varies based on whether you are a first-time buyer and if the property is located in a city with additional municipal taxes like Toronto.</p>
            </div>
            {faqSchema.mainEntity.map((faq) => (
                <div class="bg-slate-50 rounded-2xl p-5 border border-slate-100">
                    <h3 class="font-bold text-slate-900 mb-2">{faq.name}</h3>
                    <p class="text-slate-600 text-sm">{faq.acceptedAnswer.text}</p>
                </div>
            ))}
        </div>
    </div>

  </section>
</BaseLayout>
